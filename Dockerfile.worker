# Multi-stage Dockerfile for the worker
FROM golang:1.21 AS builder
WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 GOOS=linux GOARCH=amd64 go build -ldflags='-s -w' -o /app/worker ./cmd/worker

FROM scratch
COPY --from=builder /app/worker /app/worker
ENTRYPOINT ["/app/worker"]
