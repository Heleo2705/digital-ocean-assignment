# Multi-stage Dockerfile for a tiny webhook receiver used in E2E tests
FROM golang:1.21 AS builder
WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 GOOS=linux GOARCH=amd64 go build -ldflags='-s -w' -o /app/webhook ./cmd/webhook

FROM scratch
COPY --from=builder /app/webhook /app/webhook
EXPOSE 9000
ENTRYPOINT ["/app/webhook"]
